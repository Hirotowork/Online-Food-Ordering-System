<view class="page">
  <view class="card summary-card">
    <view class="page-title">选桌</view>
    <view class="page-subtitle">请选择一个空闲餐桌开始点餐。</view>
  </view>

  <view wx:if="{{currentTable}}" class="card current-card">
    <view class="section-title">当前已占用餐桌</view>
    <view class="current-row">
      <view>
        <view class="table-no">{{currentTable.no}}</view>
        <view class="muted">{{currentTable.unit}}</view>
      </view>
      <button class="mini-action" bindtap="goMenu">去点餐</button>
    </view>
  </view>

  <view class="section-header">
    <view class="section-title">餐桌列表</view>
    <view class="muted">{{availableCount}} 个空闲</view>
  </view>

  <view wx:if="{{!loading && tables.length === 0}}" class="card empty-state">
    当前没有餐桌数据
  </view>

  <view wx:for="{{tables}}" wx:key="id" class="card table-card">
    <view class="table-head">
      <view>
        <view class="table-no">{{item.no}}</view>
        <view class="muted">{{item.unit}}</view>
      </view>
      <view class="status {{item.free === '是' ? 'status-free' : 'status-busy'}}">
        {{item.free === '是' ? '空闲' : '占用中'}}
      </view>
    </view>

    <button
      wx:if="{{item.free === '是'}}"
      class="primary-btn"
      data-index="{{index}}"
      bindtap="reserveTable"
      loading="{{reserveLoadingId === item.id}}"
      disabled="{{reserveLoadingId === item.id}}"
    >
      开始点餐
    </button>

    <button wx:else class="secondary-btn" disabled="true">
      当前不可用
    </button>
  </view>
</view>
