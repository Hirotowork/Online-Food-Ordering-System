.profile-card {
  background: linear-gradient(135deg, #0f172a, #1f2937);
  color: #ffffff;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.avatar-image,
.avatar-fallback {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-main {
  flex: 1;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
}

.form-card {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #334155;
}

.field-input {
  height: 92rpx;
  padding: 0 28rpx;
  margin-bottom: 28rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #dbe5e4;
  box-sizing: border-box;
}

.segmented {
  display: flex;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #dbe5e4;
  color: #475569;
}

.segment-item-active {
  background: #ecfeff;
  color: #0f766e;
  border-color: #99f6e4;
  font-weight: 700;
}

.logout-btn {
  margin-top: 24rpx;
  background: transparent;
  color: #64748b;
  font-size: 28rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}
