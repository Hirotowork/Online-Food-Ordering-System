<view class="page">
  <view class="card profile-card">
    <view class="profile-top">
      <view class="avatar-wrap" bindtap="chooseAvatar">
        <image wx:if="{{user.avatar}}" class="avatar-image" src="{{user.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-fallback">{{avatarText}}</view>
      </view>

      <view class="profile-main">
        <view class="profile-name">{{user.name || '未登录用户'}}</view>
        <view class="profile-meta">账号：{{user.username || 'unknown'}}</view>
        <view class="profile-meta">余额：￥{{accountText}}</view>
      </view>
    </view>
  </view>

  <view class="card form-card">
    <view class="field-label">昵称</view>
    <input
      class="field-input"
      type="text"
      maxlength="20"
      placeholder="请输入昵称"
      value="{{form.name}}"
      bindinput="onNameInput"
    />

    <view class="field-label">手机号</view>
    <input
      class="field-input"
      type="number"
      maxlength="11"
      placeholder="请输入手机号"
      value="{{form.phone}}"
      bindinput="onPhoneInput"
    />

    <view class="field-label">性别</view>
    <view class="segmented">
      <view
        class="segment-item {{form.sex === '男' ? 'segment-item-active' : ''}}"
        data-value="男"
        bindtap="selectSex"
      >
        男
      </view>
      <view
        class="segment-item {{form.sex === '女' ? 'segment-item-active' : ''}}"
        data-value="女"
        bindtap="selectSex"
      >
        女
      </view>
    </view>

    <button class="primary-btn" loading="{{saving}}" disabled="{{saving}}" bindtap="saveProfile">
      保存资料
    </button>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
</view>
