.summary-card {
  margin-bottom: 24rpx;
}

.order-card {
  margin-bottom: 20rpx;
}

.order-top,
.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-no {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.order-time {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}

.order-content {
  margin: 24rpx 0;
  color: #334155;
  line-height: 1.8;
}

.order-total {
  font-size: 30rpx;
  font-weight: 700;
  color: #dc2626;
}

.status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.status-preparing {
  background: #fef3c7;
  color: #92400e;
}

.status-pending {
  background: #dbeafe;
  color: #1d4ed8;
}

.status-finished {
  background: #dcfce7;
  color: #166534;
}

.status-btn {
  width: auto;
  padding: 0 24rpx;
}
