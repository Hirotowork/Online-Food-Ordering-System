<view class="page">
  <view class="card summary-card">
    <view class="page-title">我的订单</view>
    <view class="page-subtitle">查看订单状态并完成结算。</view>
  </view>

  <view wx:if="{{!loading && orders.length === 0}}" class="card empty-state">
    还没有订单，先去点几道菜
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="card order-card">
    <view class="order-top">
      <view>
        <view class="order-no">订单号 {{item.orderNo}}</view>
        <view class="order-time">{{item.time}}</view>
      </view>
      <view class="status {{item.statusClass}}">{{item.status}}</view>
    </view>

    <view class="order-content">{{item.content}}</view>

    <view class="order-bottom">
      <view class="order-total">合计 ￥{{item.totalText}}</view>
      <button
        wx:if="{{item.status === '待结算'}}"
        class="mini-primary-btn"
        data-index="{{index}}"
        bindtap="settleOrder"
        disabled="{{settlingId === item.id}}"
        loading="{{settlingId === item.id}}"
      >
        立即结算
      </button>
      <button wx:elif="{{item.status === '待出餐'}}" class="secondary-btn status-btn" disabled="true">
        等待出餐
      </button>
      <button wx:else class="secondary-btn status-btn" disabled="true">
        已完成
      </button>
    </view>
  </view>
</view>
