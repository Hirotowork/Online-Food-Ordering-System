.login-page {
  background:
    radial-gradient(circle at top left, rgba(20, 184, 166, 0.22), transparent 34%),
    linear-gradient(180deg, #effcf8 0%, #f4f7f6 38%, #f4f7f6 100%);
}

.hero {
  padding: 40rpx 8rpx 32rpx;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.1);
  color: #0f766e;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #0f172a;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: #475569;
  line-height: 1.7;
}

.form-card {
  margin-top: 20rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #334155;
}

.field-input {
  height: 92rpx;
  padding: 0 28rpx;
  margin-bottom: 28rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #dbe5e4;
  box-sizing: border-box;
}
