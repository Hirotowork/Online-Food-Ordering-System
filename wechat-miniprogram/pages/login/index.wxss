.login-page {
  background: #f8f8ff;
}

.hero {
  padding: 56rpx 8rpx 32rpx;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #1450aa;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: #666;
  line-height: 1.7;
}

.form-card {
  margin-top: 20rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #333;
}

.field-input {
  height: 92rpx;
  padding: 0 28rpx;
  margin-bottom: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid #dbe6ff;
  box-sizing: border-box;
}

.switch-btn {
  margin-top: 20rpx;
}
