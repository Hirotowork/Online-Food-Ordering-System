page {
  background: #f8f8ff;
  color: #14213d;
  font-size: 28rpx;
  overflow-x: hidden;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(20, 80, 170, 0.08);
  box-sizing: border-box;
}

button {
  box-sizing: border-box;
}

button::after {
  border: none;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1450aa;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #64748b;
  line-height: 1.6;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #1450aa;
  color: #ffffff;
  font-size: 30rpx;
  border: none;
}

.primary-btn[disabled] {
  opacity: 0.5;
}

.secondary-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #e9eeff;
  color: #1450aa;
  font-size: 28rpx;
  border: 2rpx solid #cfd9ff;
}

.muted {
  color: #64748b;
}

.empty-state {
  text-align: center;
  padding: 72rpx 32rpx;
  color: #64748b;
}
